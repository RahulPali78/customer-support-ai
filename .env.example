# Customer Support AI - Environment Variables
# Copy this file to .env and fill in your actual credentials

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-key-here

# Gmail OAuth2 (for email ingestion)
# Get these from Google Cloud Console
GMAIL_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-google-client-secret

# Slack Bot Token (for notifications)
# Get from api.slack.com/apps → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL=#support-auto
SLACK_ESCALATION_CHANNEL=#support-escalations

# Optional: n8n Webhook URL (for manual triggers)
N8N_WEBHOOK_URL=https://your-n8n.app/webhook/email-check

# Optional: Company info for email signatures
COMPANY_NAME=Your Company Ltd
COMPANY_EMAIL=support@yourcompany.com

# n8n Configuration (if self-hosted)
N8N_API_KEY=n8n_api_xxxxxxxxxx
N8N_HOST=https://your-n8n.app

# Dashboard Configuration
STREAMLIT_PORT=8501